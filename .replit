run = "bash start.sh"

[nix]
channel = "stable-24_05"

[deployment]
run = ["bash", "start.sh"]
deploymentTarget = "cloudrun"

[[deployment.build]]
command = "pip install -r requirements.txt"

# Disable auto git push from Replit to avoid conflicts
# The deployment server should only PULL from GitHub, never PUSH
[git]
autopush = false
